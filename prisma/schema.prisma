// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  WORKER
}

enum TipoEntrega {
  LOCAL
  LLEVAR
  DOMICILIO
}

enum EstadoPedido {
  PENDIENTE
  EN_PREPARACION
  LISTO
  ENTREGADO
  CANCELADO
}

enum FormaPago {
  EFECTIVO
  TARJETA
  TRANSFERENCIA
}


model User {
  id        String   @id @default(uuid())
  name      String
  role      UserRole
  username  String   @unique
  password  String
  available Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Proovedores {
  id                 String   @id @default(uuid())
  nombreProveedor    String
  telefonoProveedor  String
  domicilioProveedor String
  rfcProveedor       String
  emailProveedor     String
  tipoProducto       String
  disponible         Boolean?
}

model CategoriaMenu {
  id              String   @id @default(uuid())
  nombreCategoria String
  descripcion     String
  disponible      Boolean  @default(true)
  menus           Menu[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
}

model Menu {
  id           String        @id @default(uuid())
  nombre       String
  precio       Float
  ingredientes String[]      @default([])
  tamano       String
  disponible   Boolean       @default(true)
  categoria    CategoriaMenu @relation(fields: [categoriaId], references: [id])
  categoriaId  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  detallePedido DetallePedido[]
}

model InfoPizzeria {
  id String @id @default(uuid()) 
  nombre String
  telefono String
  dueno String
  correo String 
  logo String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Clientes {
  id          String    @id @default(uuid())
  nombre      String
  telefono    String
  email       String    @unique
  direccion   String
  cumpleanos  DateTime?
  referencias String?
  disponible  Boolean   @default(true)
  pedidos     Pedidos[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Sucursales {
  id          String      @id @default(uuid())
  nombre      String
  direccion   String
  responsable String
  telefono    String
  municipio   String
  estado      String
  cp          String
  horario     String
  disponible  Boolean     @default(true)
  empleados   Empleados[]
  pedidos     Pedidos[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Empleados {
  id              String     @id @default(uuid())
  nombre          String
  apellido        String
  puesto          String
  fechaNacimiento DateTime
  domicilio       String
  telefono        String
  correo          String     @unique
  numEmergencia   String
  tipoSangre      String
  discapacidad    Boolean    @default(false)
  genero          String
  sucursal        Sucursales @relation(fields: [sucursalId], references: [id])
  sucursalId      String
  disponible      Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

model Pedidos {
  id           String          @id @default(uuid())
  numeroPedido Int             @unique @default(autoincrement())
  fechaHora    DateTime        @default(now())
  numeroMesa   Int?
  cliente      Clientes        @relation(fields: [clienteId], references: [id])
  clienteId    String
  sucursal     Sucursales      @relation(fields: [sucursalId], references: [id])
  sucursalId   String
  tipoEntrega  TipoEntrega
  estado       EstadoPedido    @default(PENDIENTE)
  disponible   Boolean         @default(true)
  detalles     DetallePedido[]
  ticket       Tickets?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model DetallePedido {
  id             String   @id @default(uuid())
  pedido         Pedidos  @relation(fields: [pedidoId], references: [id])
  pedidoId       String
  menu           Menu     @relation(fields: [menuId], references: [id])
  menuId         String
  cantidad       Int
  extras         String[] @default([])
  termino        String
  precioUnitario Float
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Tickets {
  id           String   @id @default(uuid())
  numeroTicket Int      @unique @default(autoincrement())
  fechaHora    DateTime @default(now())
  pedidoId     String   @unique
  pedido       Pedidos  @relation(fields: [pedidoId], references: [id])
  subtotal     Float
  iva          Float
  total        Float
  descuento    Float    @default(0)
  tarifaEnvio  Float    @default(0)
  caja         Cajas? 
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Cajas {
  id             String    @id @default(uuid())
  numeroCaja     Int       @unique @default(autoincrement())
  ticket         Tickets   @relation(fields: [ticketId], references: [id])
  ticketId       String    @unique
  formaPago      FormaPago
  referenciaPago String?
  fechaPago      DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}