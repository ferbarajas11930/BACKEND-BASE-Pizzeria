generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  WORKER
}

model User {
  id        String   @id @default(uuid())
  name      String
  role      UserRole
  username  String   @unique
  password  String
  available Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Proovedores {
  id                 String   @id @default(uuid())
  nombreProveedor    String
  telefonoProveedor  String
  domicilioProveedor String
  rfcProveedor       String
  emailProveedor     String
  tipoProducto       String
  disponible         Boolean?
}

model CategoriaMenu {
  id              String   @id @default(uuid())
  nombreCategoria String
  descripcion     String
  disponible      Boolean  @default(true)
  menus           Menu[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
}

model Menu {
  id           String        @id @default(uuid())
  nombre       String
  precio       Float
  ingredientes String[]      @default([])
  tamano       String
  disponible   Boolean       @default(true)
  categoria    CategoriaMenu @relation(fields: [categoriaId], references: [id])
  categoriaId  String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model InfoPizzeria {
  id String @id @default(uuid()) 
  nombre String
  telefono String
  dueno String
  correo String 
  logo String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}